# Copy to `.env.development.local` and edit as needed.
#
# When true, `services/api.js` resolves to `mocks/` and the app works
# without a running Express server (hand-written JSON fixtures).
# When false, it resolves to `services/api.real.js`, which calls the
# API at `src/config.json -> api_base`.
REACT_APP_USE_MOCKS=true
