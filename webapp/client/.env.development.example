# Copy to `.env.development.local` and edit as needed.
# CRA auto-loads .env.development.local during `npm start`.
# All vars MUST be prefixed REACT_APP_* to be inlined into the build.

# --- Mock toggle --------------------------------------------------------
# true  -> `services/api.js` resolves to `mocks/` (static JSON fixtures),
#          so the app works without a running Express server.
# false -> resolves to `services/api.real.js`, which calls the Express API
#          at REACT_APP_API_ORIGIN (below) + /api/v1.
REACT_APP_USE_MOCKS=true

# --- API origin ---------------------------------------------------------
# Scheme + host + port of the API server. NO path — the /api/v1 version
# prefix is part of the contract and lives in code. Leave unset to default
# to same-origin (works behind a reverse proxy that fronts both apps).
#
# Set the full origin during local dev where React (:3000) and Express
# (:8080) run on different ports:
REACT_APP_API_ORIGIN=http://localhost:8080
